{
  "dashboard": {
    "id": null,
    "uid": "graft-ai-aig-overview",
    "title": "graft-ai — AI Gateway Overview",
    "description": "Cloudflare AI Gateway logs via graft-ai pipeline (Loki)",
    "tags": ["graft-ai", "cloudflare", "ai-gateway", "loki"],
    "timezone": "browser",
    "schemaVersion": 39,
    "version": 1,
    "refresh": "30s",
    "time": { "from": "now-24h", "to": "now" },
    "timepicker": {},
    "templating": {
      "list": [
        {
          "name": "gateway",
          "label": "Gateway",
          "type": "query",
          "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
          "definition": "label_values({env=\"prod\"}, gateway)",
          "query": "label_values({env=\"prod\"}, gateway)",
          "refresh": 2,
          "includeAll": true,
          "allValue": ".*",
          "current": { "text": "All", "value": "$__all" },
          "hide": 0
        },
        {
          "name": "model",
          "label": "Model",
          "type": "query",
          "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
          "definition": "label_values({env=\"prod\", gateway=~\"$gateway\"}, model)",
          "query": "label_values({env=\"prod\", gateway=~\"$gateway\"}, model)",
          "refresh": 2,
          "includeAll": true,
          "allValue": ".*",
          "current": { "text": "All", "value": "$__all" },
          "hide": 0
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "type": "stat",
        "title": "Total Requests",
        "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "reduceOptions": { "calcs": ["sum"] },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [{ "color": "blue", "value": null }]
            },
            "unit": "short"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "count_over_time({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | __error__=\"\" [$__range])",
            "legendFormat": "Requests",
            "refId": "A"
          }
        ]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Error Rate",
        "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "reduceOptions": { "calcs": ["mean"] },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5 },
                { "color": "red", "value": 20 }
              ]
            },
            "unit": "percent"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum(count_over_time({env=\"prod\", gateway=~\"$gateway\", status_code=~\"4..|5..\"} [$__range])) / sum(count_over_time({env=\"prod\", gateway=~\"$gateway\"} [$__range])) * 100",
            "legendFormat": "Error %",
            "refId": "A"
          }
        ]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Avg Latency",
        "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "reduceOptions": { "calcs": ["mean"] },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 1000 },
                { "color": "red", "value": 3000 }
              ]
            },
            "unit": "ms"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "avg_over_time({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | unwrap duration_ms [$__range])",
            "legendFormat": "avg ms",
            "refId": "A"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Total Tokens",
        "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "reduceOptions": { "calcs": ["sum"] },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [{ "color": "purple", "value": null }]
            },
            "unit": "short"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum_over_time({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | unwrap total_tokens [$__range])",
            "legendFormat": "tokens",
            "refId": "A"
          }
        ]
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Active Models",
        "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "reduceOptions": { "calcs": ["lastNotNull"] },
          "orientation": "auto",
          "textMode": "auto",
          "colorMode": "background",
          "graphMode": "none"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [{ "color": "semi-dark-blue", "value": null }]
            },
            "unit": "short"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "count(count by (model) (count_over_time({env=\"prod\", gateway=~\"$gateway\", model!=\"unknown\"} [$__range])))",
            "legendFormat": "models",
            "refId": "A"
          }
        ]
      },
      {
        "id": 6,
        "type": "timeseries",
        "title": "Requests per Minute",
        "gridPos": { "x": 0, "y": 4, "w": 16, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "tooltip": { "mode": "multi", "sort": "desc" },
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": {
              "lineWidth": 2,
              "fillOpacity": 10,
              "gradientMode": "none",
              "spanNulls": false
            },
            "unit": "reqpm"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum by (status_code) (rate({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\", status_code!=\"\"} [$__interval]))",
            "legendFormat": "status={{status_code}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 7,
        "type": "piechart",
        "title": "Status Code Distribution",
        "gridPos": { "x": 16, "y": 4, "w": 8, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "pieType": "donut",
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "percent"] },
          "tooltip": { "mode": "single" }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          },
          "overrides": [
            { "matcher": { "id": "byName", "options": "status=200" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "status=401" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "status=429" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
            { "matcher": { "id": "byName", "options": "status=500" }, "properties": [{ "id": "color", "value": { "fixedColor": "dark-red", "mode": "fixed" } }] }
          ]
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum by (status_code) (count_over_time({env=\"prod\", gateway=~\"$gateway\", status_code!=\"\"} [$__range]))",
            "legendFormat": "status={{status_code}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 8,
        "type": "timeseries",
        "title": "Latency (duration_ms)",
        "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max", "p95"] }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 8 },
            "unit": "ms"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "avg_over_time({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | unwrap duration_ms [$__interval])",
            "legendFormat": "avg",
            "refId": "A"
          },
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "quantile_over_time(0.95, {env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | unwrap duration_ms [$__interval])",
            "legendFormat": "p95",
            "refId": "B"
          }
        ]
      },
      {
        "id": 9,
        "type": "bargauge",
        "title": "Requests by Model",
        "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["sum"] },
          "displayMode": "gradient",
          "valueMode": "color",
          "minVizWidth": 0,
          "minVizHeight": 10
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short",
            "thresholds": {
              "mode": "absolute",
              "steps": [{ "color": "blue", "value": null }]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum by (model) (count_over_time({env=\"prod\", gateway=~\"$gateway\", model!=\"unknown\", model!=\"\"} [$__range]))",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 10,
        "type": "timeseries",
        "title": "Token Usage over Time",
        "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "tooltip": { "mode": "multi" },
          "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "mean"] }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "custom": { "lineWidth": 2, "fillOpacity": 15 },
            "unit": "short"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum(sum_over_time({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | unwrap prompt_tokens [$__interval]))",
            "legendFormat": "prompt tokens",
            "refId": "A"
          },
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum(sum_over_time({env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | unwrap completion_tokens [$__interval]))",
            "legendFormat": "completion tokens",
            "refId": "B"
          }
        ]
      },
      {
        "id": 11,
        "type": "piechart",
        "title": "Cache Hit Rate",
        "gridPos": { "x": 12, "y": 20, "w": 6, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "pieType": "donut",
          "legend": { "displayMode": "table", "placement": "right", "calcs": ["sum", "percent"] }
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum by (cache_status) (count_over_time({env=\"prod\", gateway=~\"$gateway\"} | json | cache_status!=\"\" [$__range]))",
            "legendFormat": "{{cache_status}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 12,
        "type": "bargauge",
        "title": "Total Tokens by Model",
        "gridPos": { "x": 18, "y": 20, "w": 6, "h": 8 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "orientation": "horizontal",
          "reduceOptions": { "calcs": ["sum"] },
          "displayMode": "gradient"
        },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "palette-classic" },
            "unit": "short"
          }
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "sum by (model) (sum_over_time({env=\"prod\", gateway=~\"$gateway\", model!=\"unknown\"} | json | unwrap total_tokens [$__range]))",
            "legendFormat": "{{model}}",
            "refId": "A"
          }
        ]
      },
      {
        "id": 13,
        "type": "logs",
        "title": "Recent Logs (errors & all)",
        "gridPos": { "x": 0, "y": 28, "w": 24, "h": 10 },
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "options": {
          "showTime": true,
          "showLabels": true,
          "showCommonLabels": false,
          "wrapLogMessage": false,
          "prettifyLogMessage": false,
          "enableLogDetails": true,
          "dedupStrategy": "none",
          "sortOrder": "Descending"
        },
        "targets": [
          {
            "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
            "expr": "{env=\"prod\", gateway=~\"$gateway\", model=~\"$model\"} | json | __error__=\"\"",
            "legendFormat": "",
            "refId": "A"
          }
        ]
      }
    ]
  },
  "folderUid": "",
  "message": "graft-ai dashboard initial import",
  "overwrite": true
}
